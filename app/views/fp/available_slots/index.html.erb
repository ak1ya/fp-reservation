<% content_for :title, "予約枠管理 - FP予約システム" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-800 mb-1">予約枠管理</h1>
  <p class="text-slate-500 text-sm">受け付ける予約枠にチェックを入れて保存してください</p>
</div>

<div class="flex flex-col lg:flex-row gap-8">
  <div class="lg:w-72 flex-shrink-0">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 sticky top-4">
      <h2 class="font-semibold text-slate-700 mb-4 text-sm">日付を選択</h2>
      <% @weeks.each do |week| %>
        <div class="flex gap-1 mb-1">
          <% week.each do |day| %>
            <% is_selected = day == @target_date %>
            <% is_past = day < Date.current %>
            <%= link_to fp_available_slots_path(date: day.to_s),
                class: "flex-1 flex flex-col items-center py-1.5 rounded-lg text-xs font-medium transition-all #{
                  if is_selected
                    'bg-blue-600 text-white'
                  elsif is_past
                    'text-slate-300 cursor-not-allowed'
                  else
                    'hover:bg-blue-50 text-slate-600'
                  end
                }" do %>
              <span class="text-[9px] opacity-70"><%= %w[日 月 火 水 木 金 土][day.wday] %></span>
              <span class="font-bold"><%= day.day %></span>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="mt-6 pt-4 border-t border-slate-100">
        <div class="space-y-2 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-blue-600 rounded"></div>
            <span>受付中</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-emerald-500 rounded"></div>
            <span>予約済み</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-slate-100 border border-slate-200 rounded"></div>
            <span>未設定</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex-1">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="font-bold text-slate-800 text-lg">
            <%= @target_date.strftime("%Y年%m月%d日") %>
            （<%= %w[日 月 火 水 木 金 土][@target_date.wday] %>）
          </h2>
          <% if @target_date.wday == 6 %>
            <p class="text-slate-400 text-sm">土曜日: 11:00〜15:00</p>
          <% else %>
            <p class="text-slate-400 text-sm">平日: 10:00〜18:00</p>
          <% end %>
        </div>
      </div>

      <% if @possible_slots.any? %>
        <%= form_with url: fp_available_slots_path, method: :post, local: true, class: "space-y-3" do |f| %>
          <%= hidden_field_tag :slot_date, @target_date.to_s %>

          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            <% @possible_slots.each do |slot| %>
              <% existing = @my_slots[slot[:start_time]] %>
              <% is_booked = existing&.booked? %>
              <label class="relative cursor-pointer <%= 'cursor-not-allowed' if is_booked %>">
                <input
                  type="checkbox"
                  name="slots[]"
                  value="<%= slot[:start_time] %>"
                  class="sr-only peer"
                  <%= existing ? 'checked' : '' %>
                  <%= 'disabled' if is_booked %>
                >
                <div class="
                  p-4 rounded-xl border-2 transition-all select-none
                  <%= if is_booked
                        'bg-emerald-50 border-emerald-300 opacity-80'
                      else
                        'border-slate-200 hover:border-blue-300 peer-checked:bg-blue-50 peer-checked:border-blue-500'
                      end
                  %>
                ">
                  <div class="font-bold text-sm <%= is_booked ? 'text-emerald-700' : 'text-slate-800' %>">
                    <%= slot[:start_time] %>
                  </div>
                  <div class="text-xs <%= is_booked ? 'text-emerald-500' : 'text-slate-400' %> mt-0.5">
                    〜 <%= slot[:end_time] %>
                  </div>
                  <% if is_booked %>
                    <div class="text-xs text-emerald-600 font-medium mt-2">予約済</div>
                  <% else %>
                    <div class="text-xs text-blue-500 font-medium mt-2 opacity-0 peer-checked:opacity-100">受付中</div>
                  <% end %>
                </div>
              </label>
            <% end %>
          </div>

          <div class="pt-4 flex gap-3">
            <%= f.submit "枠を保存する", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors cursor-pointer" %>
            <span class="flex items-center text-slate-400 text-sm">チェックした枠が受付対象になります</span>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-10 text-slate-400">
          <p>この日は営業日外です（日曜日）</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
