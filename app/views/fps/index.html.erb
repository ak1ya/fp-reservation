<% content_for :title, "FP一覧 - FP予約システム" %>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-slate-800 mb-2">FP一覧</h1>
  <p class="text-slate-500">ファイナンシャルプランナーを選んで予約してください</p>
</div>

<% if @fps.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @fps.each do |fp| %>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition-shadow group">
        <div class="bg-gradient-to-br from-blue-500 to-blue-700 p-6 flex items-center gap-4">
          <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center text-white font-bold text-2xl">
            <%= fp.name[0] %>
          </div>
          <div>
            <div class="text-white font-bold text-lg"><%= fp.name %></div>
            <div class="text-blue-200 text-sm"><%= fp.email %></div>
          </div>
        </div>
        <div class="p-5">
          <div class="flex items-center gap-2 mb-4">
            <div class="flex items-center gap-1.5 bg-emerald-50 border border-emerald-200 rounded-full px-3 py-1">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              <span class="text-emerald-700 text-xs font-medium">
                空き枠 <%= fp.available_slots.available.upcoming.count %>件
              </span>
            </div>
          </div>
          <%= link_to "予約枠を見る", fp_path(fp), class: "w-full block text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl transition-colors text-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-2xl border border-slate-100">
    <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    </div>
    <p class="text-slate-500 font-medium mb-2">FPが登録されていません</p>
    <p class="text-slate-400 text-sm">FPが登録されるまでお待ちください</p>
  </div>
<% end %>
