<% content_for :title, "#{@fp.name}の予約 - FP予約システム" %>

<div class="flex flex-col lg:flex-row gap-8">
  <div class="lg:w-72 flex-shrink-0">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden sticky top-4">
      <div class="bg-gradient-to-br from-blue-500 to-blue-700 p-6 text-center">
        <div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center text-white font-bold text-3xl mx-auto mb-3">
          <%= @fp.name[0] %>
        </div>
        <div class="text-white font-bold text-xl"><%= @fp.name %></div>
        <div class="text-blue-200 text-sm mt-1"><%= @fp.email %></div>
      </div>
      <div class="p-5">
        <div class="text-sm text-slate-500 mb-4">
          <div class="flex justify-between items-center py-2 border-b border-slate-50">
            <span>今後の空き枠</span>
            <span class="font-semibold text-blue-600"><%= @fp.available_slots.available.upcoming.count %>件</span>
          </div>
        </div>
        <% unless logged_in? %>
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-xs text-amber-700">
            予約するには<%= link_to "ログイン", login_path, class: "font-semibold underline" %>が必要です
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex-1">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6">
      <h2 class="font-semibold text-slate-800 mb-4">日付を選択</h2>
      <% @weeks.each_with_index do |week, wi| %>
        <div class="flex gap-2 mb-2">
          <% week.each do |day| %>
            <% is_selected = day == @target_date %>
            <% is_past = day < Date.current %>
            <%= link_to fp_path(@fp, date: day.to_s),
                class: "flex-1 flex flex-col items-center py-2 px-1 rounded-xl text-xs font-medium transition-all #{
                  if is_selected
                    'bg-blue-600 text-white shadow-sm'
                  elsif is_past
                    'text-slate-300 cursor-not-allowed'
                  else
                    'hover:bg-blue-50 text-slate-600 border border-slate-100 hover:border-blue-200'
                  end
                }" do %>
              <span class="text-[10px] <%= is_selected ? 'text-blue-200' : 'text-slate-400' %>">
                <%= %w[日 月 火 水 木 金 土][day.wday] %>
              </span>
              <span class="text-sm font-bold mt-0.5"><%= day.day %></span>
              <span class="text-[10px] <%= is_selected ? 'text-blue-200' : 'text-slate-400' %>">
                <%= day.month %>/<%= day.day %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <h2 class="font-semibold text-slate-800 mb-1">
        <%= @target_date.strftime("%Y年%m月%d日") %>
        （<%= %w[日 月 火 水 木 金 土][@target_date.wday] %>）の空き枠
      </h2>
      <p class="text-slate-400 text-sm mb-5">クリックして予約してください</p>

      <% if @slots.any? %>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <% @slots.each do |slot| %>
            <% if logged_in? && !current_user.fp? %>
              <%= button_to reservations_path, method: :post, params: { available_slot_id: slot.id },
                  class: "slot-card group bg-emerald-50 hover:bg-emerald-500 border-2 border-emerald-200 hover:border-emerald-500 rounded-xl p-4 transition-all cursor-pointer text-left" do %>
                <div class="text-emerald-700 group-hover:text-white font-bold text-base"><%= slot.start_time_str %></div>
                <div class="text-emerald-500 group-hover:text-emerald-100 text-xs mt-0.5">〜 <%= slot.end_time_str %></div>
                <div class="text-xs text-emerald-600 group-hover:text-emerald-200 mt-2 font-medium">予約する →</div>
              <% end %>
            <% else %>
              <div class="bg-emerald-50 border-2 border-emerald-200 rounded-xl p-4">
                <div class="text-emerald-700 font-bold text-base"><%= slot.start_time_str %></div>
                <div class="text-emerald-500 text-xs mt-0.5">〜 <%= slot.end_time_str %></div>
                <% unless logged_in? %>
                  <div class="text-xs text-emerald-400 mt-2">要ログイン</div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-10 text-slate-400">
          <svg class="w-12 h-12 mx-auto mb-3 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="font-medium">この日の空き枠はありません</p>
          <p class="text-sm mt-1">他の日付を選択してください</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
