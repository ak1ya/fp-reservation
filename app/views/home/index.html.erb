<% content_for :title, "FP予約システム - ホーム" %>

<section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-800 via-blue-900 to-slate-900 text-white px-8 py-16 mb-12">
  <div class="relative z-10 max-w-2xl">
    <div class="inline-flex items-center gap-2 bg-blue-500/20 border border-blue-400/30 rounded-full px-4 py-1.5 mb-6">
      <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
      <span class="text-blue-300 text-sm font-medium">無料相談受付中</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
      ファイナンシャルプランナーに<br>
      <span class="text-blue-400">気軽に相談</span>
    </h1>
    <p class="text-slate-300 text-lg mb-8 leading-relaxed">
      資産運用・保険・老後資金など、お金に関する悩みをプロのFPに相談できます。<br>
      30分の無料相談枠で、あなたの疑問を解決しましょう。
    </p>
    <div class="flex flex-wrap gap-4">
      <% if logged_in? && !current_user.fp? %>
        <%= link_to fps_path, class: "bg-blue-500 hover:bg-blue-400 text-white font-semibold px-6 py-3 rounded-xl transition-all transform hover:scale-105 shadow-lg" do %>
          FPを探す →
        <% end %>
      <% elsif !logged_in? %>
        <%= link_to fps_path, class: "bg-blue-500 hover:bg-blue-400 text-white font-semibold px-6 py-3 rounded-xl transition-all transform hover:scale-105 shadow-lg" do %>
          FPを探す →
        <% end %>
        <%= link_to register_path, class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-all border border-white/20" do %>
          新規登録
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 right-1/4 w-48 h-48 bg-blue-400/5 rounded-full translate-y-1/2"></div>
</section>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
  <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100">
    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
      <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
    <h3 class="font-semibold text-slate-800 mb-2">かんたん予約</h3>
    <p class="text-slate-500 text-sm">空き枠を選ぶだけで予約完了。キャンセルも自由。</p>
  </div>
  <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100">
    <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center mb-4">
      <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
    </div>
    <h3 class="font-semibold text-slate-800 mb-2">認定FP在籍</h3>
    <p class="text-slate-500 text-sm">資格を持つプロのFPが丁寧に対応します。</p>
  </div>
  <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100">
    <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
      <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <h3 class="font-semibold text-slate-800 mb-2">30分制</h3>
    <p class="text-slate-500 text-sm">1枠30分。平日10〜18時、土曜11〜15時に対応。</p>
  </div>
</div>

<% if @fps.any? %>
  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-slate-800">在籍FP一覧</h2>
      <%= link_to "すべて見る →", fps_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @fps.first(3).each do |fp| %>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white font-bold text-lg">
              <%= fp.name[0] %>
            </div>
            <div>
              <div class="font-semibold text-slate-800"><%= fp.name %></div>
              <div class="text-xs text-slate-500"><%= fp.email %></div>
            </div>
          </div>
          <div class="text-sm text-slate-500 mb-4">
            空き枠: <span class="font-semibold text-blue-600"><%= fp.available_slots.available.upcoming.count %>件</span>
          </div>
          <%= link_to "予約する", fp_path(fp), class: "w-full block text-center bg-blue-50 hover:bg-blue-100 text-blue-700 font-medium py-2 rounded-lg transition-colors text-sm" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
