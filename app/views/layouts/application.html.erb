<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "FP予約システム" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 min-h-screen flex flex-col">
    <nav class="bg-gradient-to-r from-slate-800 to-blue-900 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-8">
            <%= link_to root_path, class: "flex items-center gap-2" do %>
              <div class="w-8 h-8 bg-blue-400 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-sm">FP</span>
              </div>
              <span class="text-white font-semibold text-lg tracking-wide">FP予約システム</span>
            <% end %>
            <div class="hidden md:flex items-center gap-6">
              <%= link_to "FP一覧", fps_path, class: "text-slate-300 hover:text-white text-sm font-medium transition-colors" %>
              <% if logged_in? && !current_user.fp? %>
                <%= link_to "マイ予約", reservations_path, class: "text-slate-300 hover:text-white text-sm font-medium transition-colors" %>
              <% end %>
              <% if logged_in_as_fp? %>
                <%= link_to "枠管理", fp_available_slots_path, class: "text-slate-300 hover:text-white text-sm font-medium transition-colors" %>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <% if logged_in? %>
              <div class="flex items-center gap-3">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 bg-blue-500 rounded-full flex items-center justify-center">
                    <span class="text-white text-xs font-bold"><%= current_user.name[0] %></span>
                  </div>
                  <span class="text-slate-200 text-sm hidden sm:block">
                    <%= current_user.name %>
                    <span class="ml-1 px-1.5 py-0.5 bg-blue-600 text-blue-100 text-xs rounded"><%= current_user.fp? ? "FP" : "ユーザー" %></span>
                  </span>
                </div>
                <%= button_to "ログアウト", logout_path, method: :delete, class: "text-slate-300 hover:text-white text-sm bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded-lg transition-colors" %>
              </div>
            <% else %>
              <%= link_to "ログイン", login_path, class: "text-slate-300 hover:text-white text-sm font-medium transition-colors" %>
              <%= link_to "新規登録", register_path, class: "bg-blue-500 hover:bg-blue-400 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="bg-emerald-50 border-l-4 border-emerald-500 p-4 mx-4 mt-4 rounded-r-lg" role="alert">
        <p class="text-emerald-700 text-sm font-medium"><%= notice %></p>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 border-l-4 border-red-500 p-4 mx-4 mt-4 rounded-r-lg" role="alert">
        <p class="text-red-700 text-sm font-medium"><%= alert %></p>
      </div>
    <% end %>

    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <footer class="bg-slate-800 text-slate-400 py-6 mt-8">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm">
        <p>&copy; <%= Date.current.year %> FP予約システム</p>
      </div>
    </footer>
  </body>
</html>
