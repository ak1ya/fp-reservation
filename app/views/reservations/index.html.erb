<% content_for :title, "マイ予約 - FP予約システム" %>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-slate-800 mb-2">マイ予約</h1>
  <p class="text-slate-500"><%= current_user.name %>さんの予約一覧</p>
</div>

<div class="space-y-8">
  <section>
    <h2 class="text-lg font-semibold text-slate-700 mb-4 flex items-center gap-2">
      <span class="w-1 h-5 bg-blue-500 rounded-full inline-block"></span>
      今後の予約
    </h2>
    <% if @upcoming.any? %>
      <div class="space-y-3">
        <% @upcoming.each do |reservation| %>
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex flex-col items-center justify-center flex-shrink-0">
              <span class="text-blue-600 font-bold text-lg leading-none"><%= reservation.available_slot.slot_date.day %></span>
              <span class="text-blue-400 text-xs"><%= reservation.available_slot.slot_date.strftime("%m月") %></span>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-semibold text-slate-800"><%= reservation.fp.name %> FP</span>
                <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">FP</span>
              </div>
              <div class="text-slate-500 text-sm">
                <%= reservation.available_slot.slot_date.strftime("%Y年%m月%d日") %>
                （<%= %w[日 月 火 水 木 金 土][reservation.available_slot.slot_date.wday] %>）
                <%= reservation.available_slot.time_range_str %>
              </div>
            </div>
            <div class="flex-shrink-0">
              <%= button_to reservation_path(reservation), method: :delete,
                  data: { turbo_confirm: "この予約をキャンセルしますか？" },
                  class: "text-sm text-red-500 hover:text-white hover:bg-red-500 border border-red-200 px-4 py-2 rounded-xl transition-all font-medium" do %>
                キャンセル
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl border border-slate-100 p-8 text-center text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="font-medium mb-1">予約がありません</p>
        <%= link_to "FPを探して予約する →", fps_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
      </div>
    <% end %>
  </section>

  <% if @past.any? %>
    <section>
      <h2 class="text-lg font-semibold text-slate-700 mb-4 flex items-center gap-2">
        <span class="w-1 h-5 bg-slate-300 rounded-full inline-block"></span>
        過去の予約（直近10件）
      </h2>
      <div class="space-y-3">
        <% @past.each do |reservation| %>
          <div class="bg-white rounded-2xl border border-slate-100 p-5 flex items-center gap-4 opacity-60">
            <div class="w-14 h-14 bg-slate-100 rounded-xl flex flex-col items-center justify-center flex-shrink-0">
              <span class="text-slate-500 font-bold text-lg leading-none"><%= reservation.available_slot.slot_date.day %></span>
              <span class="text-slate-400 text-xs"><%= reservation.available_slot.slot_date.strftime("%m月") %></span>
            </div>
            <div class="flex-1">
              <div class="font-semibold text-slate-700 mb-1"><%= reservation.fp.name %> FP</div>
              <div class="text-slate-400 text-sm">
                <%= reservation.available_slot.slot_date.strftime("%Y年%m月%d日") %>
                <%= reservation.available_slot.time_range_str %>
              </div>
            </div>
            <span class="text-xs bg-slate-100 text-slate-500 px-3 py-1 rounded-full">完了</span>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
